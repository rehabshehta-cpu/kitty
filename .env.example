# انسخي الملف ده إلى .env في نفس المجلد (لا ترفعيه إلى Git).
# المفتاح من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# نموذج الصوت (نفس عائلة "Generate speech" في AI Studio — الأحدث عادةً):
# إن فشل الطلب، جرّبي: gemini-2.5-flash-preview-tts
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
